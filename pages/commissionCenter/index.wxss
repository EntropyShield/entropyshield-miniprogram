page {
  background: #0D0D0D;
  min-height: 100%;
}
.page {
  min-height: 100vh;
  background: #0D0D0D;
  padding: 24rpx;
  box-sizing: border-box;
}

.audit-card,
.panel,
.summary-card,
.card,
.rank-card {
  background: #16181d;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.audit-title {
  font-size: 30rpx;
  color: #ffffff;
  font-weight: 700;
}

.audit-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8a8d93;
}

.audit-loading {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #8a8d93;
}

.audit-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-gap: 16rpx;
}

.audit-item {
  background: #1c1f25;
  border-radius: 18rpx;
  padding: 18rpx;
}

.audit-item-label {
  font-size: 22rpx;
  color: #8a8d93;
}

.audit-item-value {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #2aff2a;
}

.audit-foot {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #c4c7ce;
}

.top-tabs {
  display: flex;
  background: #16181d;
  border-radius: 20rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.top-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  color: #8a8d93;
  font-size: 28rpx;
  font-weight: 600;
}

.top-tab.active {
  background: linear-gradient(90deg, #18b74b, #2aff2a);
  color: #020305;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #1c1f25;
  color: #c4c7ce;
  font-size: 24rpx;
}

.chip-active {
  background: #2aff2a;
  color: #0D0D0D;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #1c1f25;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #ffffff;
  box-sizing: border-box;
}

.search-btn {
  padding: 0 24rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 16rpx;
  background: #2aff2a;
  color: #0D0D0D;
  font-size: 26rpx;
  font-weight: 700;
}

.search-btn.ghost {
  background: #2a2d33;
  color: #ffffff;
}

.summary-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.summary-title {
  font-size: 28rpx;
  color: #c4c7ce;
}

.summary-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2aff2a;
}

.loading,
.empty {
  text-align: center;
  color: #8a8d93;
  font-size: 26rpx;
  padding: 40rpx 0;
}

.card-head,
.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-head {
  margin-bottom: 18rpx;
}

.order-no {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 600;
  word-break: break-all;
  flex: 1;
  margin-right: 16rpx;
}

.status-tag {
  padding: 8rpx 16rpx;
  background: rgba(42,255,42,0.12);
  color: #2aff2a;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.row {
  margin-bottom: 12rpx;
}

.label {
  font-size: 24rpx;
  color: #8a8d93;
  width: 160rpx;
}

.value {
  flex: 1;
  text-align: right;
  font-size: 24rpx;
  color: #ffffff;
  word-break: break-all;
}

.strong {
  font-weight: 700;
  color: #2aff2a;
}

.rank-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rank-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.rank-no {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 50%;
  background: #2aff2a;
  color: #0D0D0D;
  font-size: 28rpx;
  font-weight: 700;
  margin-right: 18rpx;
}

.rank-info {
  flex: 1;
  min-width: 0;
}

.rank-name {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}

.rank-openid {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8a8d93;
  word-break: break-all;
}

.rank-right {
  text-align: right;
  margin-left: 20rpx;
}

.rank-value {
  font-size: 32rpx;
  color: #2aff2a;
  font-weight: 700;
}

.rank-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8a8d93;
}
.page-wrap {
  background: #0D0D0D;
  min-height: 100vh;
}
