.page {
  min-height: 100vh;
  background: #060b08;
  padding: 32rpx;
  box-sizing: border-box;
}

.card {
  background: #0c1510;
  border: 1px solid rgba(42,255,42,0.18);
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 0 24rpx rgba(42,255,42,0.08);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2aff2a;
  margin-bottom: 28rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.label {
  font-size: 28rpx;
  color: #8aa08d;
}

.value {
  font-size: 28rpx;
  color: #ffffff;
  max-width: 420rpx;
  text-align: right;
  word-break: break-all;
}

.btn {
  margin-top: 36rpx;
  background: #2aff2a;
  color: #071007;
  border: none;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
}