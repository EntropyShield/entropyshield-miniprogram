<view class="page">
  <view class="card">
    <view class="title">会员中心</view>

    <view class="row">
      <text class="label">当前状态</text>
      <text class="value">{{membershipName}}</text>
    </view>

    <view class="row">
      <text class="label">剩余完整方案</text>
      <text class="value">{{freeCalcTimes}}</text>
    </view>

    <view wx:if="{{membershipExpireText}}" class="row">
      <text class="label">到期时间</text>
      <text class="value">{{membershipExpireText}}</text>
    </view>

    <view wx:if="{{inviteCode}}" class="row">
      <text class="label">邀请码</text>
      <text class="value">{{inviteCode}}</text>
    </view>

    <button class="btn" bindtap="goBack">返回</button>
  </view>
</view>