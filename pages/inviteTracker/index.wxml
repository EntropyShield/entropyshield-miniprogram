<view class="page">
  <view class="summary-card">
    <view class="summary-head">
      <text class="summary-title">{{texts.title}}</text>
      <button class="refresh-btn" size="mini" bindtap="fetchData" loading="{{loading}}">
        {{texts.refresh}}
      </button>
    </view>

    <view class="current-id-row">
      <text class="current-id-label">{{texts.currentId}}?</text>
      <text class="current-id-value">{{currentClientId}}</text>
    </view>

    <view class="summary-grid">
      <view class="summary-item">
        <text class="summary-label">{{texts.pending}}</text>
        <text class="summary-value">{{summary.pendingCount}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">{{texts.paid}}</text>
        <text class="summary-value">{{summary.paidCount}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">{{texts.expired}}</text>
        <text class="summary-value">{{summary.expiredCount}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">{{texts.pending}}</view>
    <view wx:if="{{pending.length}}">
      <block wx:for="{{pending}}" wx:key="id">
        <view class="card">
          <view class="name">{{item.displayName}}</view>
          <text class="meta">{{texts.bindAt}}?{{item.bind_at}}</text>
          <text class="meta">{{texts.expireAt}}?{{item.expire_at}}</text>
        </view>
      </block>
    </view>
    <view wx:else class="empty">{{texts.empty}}</view>
  </view>

  <view class="section">
    <view class="section-title">{{texts.paid}}</view>
    <view wx:if="{{paid.length}}">
      <block wx:for="{{paid}}" wx:key="id">
        <view class="card">
          <view class="name">{{item.displayName}}</view>
          <text class="meta">{{texts.paidAt}}?{{item.first_paid_at}}</text>
          <text class="meta">{{texts.amount}}??{{item.displayAmount}}</text>
          <text class="meta">{{texts.orderNo}}?{{item.shortOrderNo}}</text>
          <text class="meta">{{texts.level}}?{{item.membershipLevelText}}</text>
        </view>
      </block>
    </view>
    <view wx:else class="empty">{{texts.empty}}</view>
  </view>

  <view class="section">
    <view class="section-title">{{texts.expired}}</view>
    <view wx:if="{{expired.length}}">
      <block wx:for="{{expired}}" wx:key="id">
        <view class="card">
          <view class="name">{{item.displayName}}</view>
          <text class="meta">{{texts.bindAt}}?{{item.bind_at}}</text>
          <text class="meta">{{texts.expireAt}}?{{item.expire_at}}</text>
        </view>
      </block>
    </view>
    <view wx:else class="empty">{{texts.empty}}</view>
  </view>
</view>
