<!-- pages/fissionTask/index.wxml -->
<view class="page">
  <!-- 主卡：二维码 -->
  <view class="card" wx:if="{{qrcodeUrl}}">
    <view class="card-title">已建立邀请关系，可直接分享</view>
    <view class="card-sub">保存二维码发给好友，对方扫码/识别进入即可自动绑定关系</view>

    <view class="qr-wrap">
      <image class="qr-img" mode="widthFix" src="{{qrcodeUrl}}" show-menu-by-longpress="true" />
      <view class="qr-tip">长按二维码可保存/识别</view>
    </view>

    <view class="btn-row">
      <button class="btn btn-primary" open-type="share">一键分享</button>
      <button class="btn btn-ghost" bindtap="goCamp">去训练营</button>
    </view>
  </view>

  <view class="card" wx:else>
    <view class="card-title">二维码加载中</view>
    <view class="card-sub">若长时间不显示，请返回重进或稍后再试</view>
  </view>

  <!-- 数据卡：关系/奖励 -->
  <view class="card">
    <view class="grid">
      <view class="metric metric-center">
        <view class="m-label">我的邀请码</view>
        <view class="m-value">{{myInviteCode || '待生成'}}</view>
      </view>

      <view class="metric metric-center">
        <view class="m-label">邀请关系</view>
        <view class="m-value">{{invitedByCode ? invitedByCode : '未绑定'}}</view>
      </view>

      <view class="metric metric-center">
        <view class="m-label">成长分</view>
        <view class="m-value">{{totalRewardTimes || 0}}</view>
      </view>
    </view>
  </view>

  <!-- 底部 -->
  <view class="footer">
    <button class="btn btn-ghost" bindtap="goHome">回首页</button>
  </view>

  <!-- 成长中心入口 -->
  <view class="commission-entry-link" bindtap="goGrowthCenter">
    <view class="commission-entry-card">
      <view class="commission-entry-title">成长中心</view>
      <view class="commission-entry-desc">
        邀请码：{{myInviteCode || '待生成'}} ｜ 邀请人：{{invitedByCode || '暂无'}} ｜ 成长分：{{totalRewardTimes || 0}}
      </view>
    </view>
  </view>
</view>