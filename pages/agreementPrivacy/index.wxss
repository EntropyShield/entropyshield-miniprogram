.page {
  min-height: 100vh;
  background: #0d0d0d;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #16181d;
  border-radius: 24rpx;
  padding: 28rpx 24rpx 40rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.update-time {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a8d93;
}

.section {
  margin-top: 28rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2aff2a;
  margin-bottom: 10rpx;
}

.paragraph {
  font-size: 24rpx;
  line-height: 1.8;
  color: #c4c7ce;
}