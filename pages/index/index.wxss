/* HOME_UI_V4_MICROFIX */
.hero-points {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  justify-content: center;
}

.hero-point {
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.section-title {
  display: block;
}

.section-sub {
  display: block;
  margin-top: 10rpx;
}

/* HOME_UI_V5_POINTS_ALIGN */
.hero-points {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 2rpx;
}

.hero-point {
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
  padding: 10rpx 0;
  border-radius: 16rpx;
  text-align: center;
  justify-content: center;
  font-size: 18rpx;
}

