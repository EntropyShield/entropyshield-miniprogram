.page {
  min-height: 100vh;
  background-color: #000000;
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
  color: #ffffff;
}

.card {
  background-color: #050505;
  border-radius: 24rpx;
  padding: 24rpx 24rpx 28rpx;
  margin-bottom: 16rpx;
  border: 1px solid rgba(42, 255, 42, 0.14);
  box-shadow: 0 0 18rpx rgba(0, 0, 0, 0.48);
}

.brand-card {
  border-color: #2aff2a33;
}

.hero-card {
  padding-top: 24rpx;
  padding-bottom: 24rpx;
}

.brand-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 18rpx;
}

.brand-logo {
  width: 92rpx;
  height: 92rpx;
  border-radius: 20rpx;
  background-color: #020202;
  margin-right: 18rpx;
  margin-top: 4rpx;
}

.brand-text {
  flex: 1;
}

.hero-eyebrow {
  font-size: 20rpx;
  color: #2aff2a;
  margin-bottom: 6rpx;
}

.brand-title text {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.42;
}

.hero-subtitle {
  margin-top: 14rpx;
}

.hero-subtitle text {
  font-size: 24rpx;
  color: #dbe5e9;
  line-height: 1.82;
}

.btn-primary {
  margin-top: 6rpx;
  margin-bottom: 12rpx;
  width: 100%;
  height: 84rpx;
  border-radius: 999rpx;
  background-color: #2aff2a;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #000000;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
}

.hero-primary {
  margin-bottom: 10rpx;
}

.btn-secondary {
  margin-top: 0;
  width: 100%;
  height: 76rpx;
  border-radius: 999rpx;
  border: 1px solid #2aff2a;
  background-color: transparent;
  color: #2aff2a;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-secondary {
  margin-bottom: 12rpx;
}

.hero-points {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.hero-point {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #0b140b;
  border: 1px solid #204620;
  color: #e7f3e8;
  font-size: 20rpx;
}

.section-card {
  padding-top: 2rpx;
}

.section-header {
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.38;
}

.section-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #c4d0d6;
  line-height: 1.78;
}

.reason-grid {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.reason-item {
  padding: 18rpx 16rpx;
  border-radius: 16rpx;
  background: #0c0f0c;
  border: 1px solid #162216;
}

.reason-title {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 600;
  line-height: 1.42;
}

.reason-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #c4d0d6;
  line-height: 1.76;
}

.test-item {
  margin-top: 8rpx;
  padding: 16rpx 2rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1px solid #151515;
}

.test-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.bullet {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.bullet-green {
  background-color: #2aff2a;
}

.test-text {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.test-title {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 600;
  line-height: 1.42;
}

.test-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #c0ccd2;
  line-height: 1.72;
}

.test-right {
  margin-left: 12rpx;
  flex-shrink: 0;
}

.test-right .test-action {
  font-size: 22rpx;
  color: #2aff2a;
  font-weight: 600;
}

.benefit-list {
  margin-top: 6rpx;
  margin-bottom: 14rpx;
}

.benefit-item {
  display: flex;
  align-items: flex-start;
  margin-top: 12rpx;
}

.benefit-tag {
  font-size: 22rpx;
  color: #fdd835;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  border: 1px solid #fdd83566;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.benefit-text {
  font-size: 22rpx;
  color: #edf1f3;
  line-height: 1.72;
}

.btn-outline {
  margin-top: 8rpx;
  width: 100%;
  height: 72rpx;
  border-radius: 999rpx;
  border: 1px dashed #fbbf24;
  background-color: #1b1204;
  color: #fbbf24;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.notice-card {
  border-style: dashed;
  border-color: #333333;
  background-color: #050505;
}

.notice-title {
  font-size: 24rpx;
  color: #c7d0d6;
  margin-bottom: 10rpx;
}

.notice-text text {
  display: block;
  font-size: 22rpx;
  color: #adb8be;
  line-height: 1.8;
}

.fit-card,
.gain-card {
  padding-top: 2rpx;
}

.fit-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.fit-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 14rpx;
  border-radius: 16rpx;
  background: #0b0f0b;
  border: 1px solid #142014;
}

.fit-dot {
  width: 24rpx;
  margin-right: 10rpx;
  color: #2aff2a;
  font-size: 28rpx;
  line-height: 1.2;
  flex-shrink: 0;
}

.fit-texts {
  flex: 1;
  min-width: 0;
}

.fit-title {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 600;
  line-height: 1.42;
}

.fit-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #c0ccd2;
  line-height: 1.76;
}

.gain-grid {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.gain-item {
  padding: 18rpx 16rpx;
  border-radius: 16rpx;
  background: #0d120d;
  border: 1px solid #183018;
}

.gain-title {
  font-size: 26rpx;
  color: #ebf7ec;
  font-weight: 600;
  line-height: 1.42;
}

.gain-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #c0ccd2;
  line-height: 1.76;
}

.home-dynamic-strip {
  display: flex;
  gap: 10rpx;
  margin-top: 0;
  margin-bottom: 10rpx;
}

.home-dynamic-item {
  flex: 1;
  min-width: 0;
  padding: 12rpx 10rpx;
  border-radius: 16rpx;
  background: #081108;
  border: 1px solid #143014;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.home-dynamic-label {
  font-size: 18rpx;
  color: #b7c4b8;
  line-height: 1.4;
}

.home-dynamic-value {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #2aff2a;
  font-weight: 700;
  text-align: center;
  line-height: 1.38;
}

.bottom-cta-card {
  border-color: #214b21;
  background: linear-gradient(180deg, #071007 0%, #050505 100%);
}

.bottom-cta-header {
  margin-bottom: 16rpx;
}

.bottom-cta-primary {
  margin-top: 0;
  margin-bottom: 12rpx;
}

.bottom-cta-secondary {
  margin-top: 0;
}

