}

.notice-title {
  margin-bottom: 10rpx;
}

.notice-text text {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #b8c3c9;
  line-height: 1.88;
  letter-spacing: 0.2rpx;
}

.home-dynamic-label {
  color: #b8c4ba;
}

.home-dynamic-value {
