}

.reason-desc,
.fit-desc,
.gain-desc,
.test-desc,
.benefit-text {
  margin-top: 10rpx !important;
  font-size: 22rpx !important;
  color: #d0d9de !important;
  line-height: 1.9 !important;
  letter-spacing: 0.2rpx;
}

.test-text {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

