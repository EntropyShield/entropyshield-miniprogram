<!-- pages/index/index.wxml -->
<view class="page">

  <!-- 首屏成交区 -->
  <view class="card brand-card hero-card">
    <view class="brand-header">
      <canvas type="2d" id="entropyLogo" class="brand-logo"></canvas>
      <view class="brand-text">
        <view class="hero-eyebrow">熵盾 · 风控先行</view>
        <view class="brand-title">
          <text>先学会控亏，再谈放大利润</text>
        </view>
        <view class="hero-subtitle">
          <text>用风控计算器、7天训练营和控局者路径，帮你从“会亏钱”走向“会控亏”。</text>
        </view>
      </view>
    </view>

    <button class="btn-primary hero-primary" bindtap="goCalc">
      立即使用风控计算器
    </button>

    <button class="btn-secondary hero-secondary" bindtap="goCamp">
      先进入 7 天风控训练营
    </button>

    <view class="hero-points">
      <view class="hero-point">固定风险</view>
      <view class="hero-point">分批建仓</view>
      <view class="hero-point">止盈止损清晰</view>
    </view>
  </view>

  <!-- 为什么先做风控 -->
  <view class="card section-card">
    <view class="section-header">
      <text class="section-title">为什么先做风控</text>
      <text class="section-sub">先把大亏挡住，才有资格谈长期复利</text>
    </view>

    <view class="reason-grid">
      <view class="reason-item">
        <text class="reason-title">不会控仓</text>
        <text class="reason-desc">仓位一重，行情一反，账户回撤会迅速放大。</text>
      </view>
      <view class="reason-item">
        <text class="reason-title">不会止损</text>
        <text class="reason-desc">没有退出规则，容易从小亏拖成大亏。</text>
      </view>
      <view class="reason-item">
        <text class="reason-title">先控亏再求胜</text>
        <text class="reason-desc">先建立可执行的风控体系，再提高胜率和收益质量。</text>
      </view>
    </view>
  </view>

  
  <!-- 适合谁 -->
  <view class="card section-card fit-card">
    <view class="section-header">
      <text class="section-title">适合谁</text>
      <text class="section-sub">如果你正处在这些状态，这一页就是为你准备的</text>
    </view>

    <view class="fit-list">
      <view class="fit-item">
        <text class="fit-dot">•</text>
        <view class="fit-texts">
          <text class="fit-title">总是满仓或重仓的人</text>
          <text class="fit-desc">一旦判断错方向，回撤会比你预想得更快更重。</text>
        </view>
      </view>

      <view class="fit-item">
        <text class="fit-dot">•</text>
        <view class="fit-texts">
          <text class="fit-title">一亏就扛单的人</text>
          <text class="fit-desc">没有清晰退出规则，小亏容易拖成大亏。</text>
        </view>
      </view>

      <view class="fit-item">
        <text class="fit-dot">•</text>
        <view class="fit-texts">
          <text class="fit-title">想先建立体系再提高收益的人</text>
          <text class="fit-desc">先把风控搭起来，再去放大胜率和收益质量。</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 你将得到什么 -->
  <view class="card section-card gain-card">
    <view class="section-header">
      <text class="section-title">你将得到什么</text>
      <text class="section-sub">不是空泛理念，而是可直接执行的风控结果</text>
    </view>

    <view class="gain-grid">
      <view class="gain-item">
        <text class="gain-title">分批建仓方案</text>
        <text class="gain-desc">知道第一笔怎么进、后续怎么补，避免一把梭。</text>
      </view>

      <view class="gain-item">
        <text class="gain-title">固定风险边界</text>
        <text class="gain-desc">先算清最多亏多少，再决定能不能做这笔交易。</text>
      </view>

      <view class="gain-item">
        <text class="gain-title">明确止盈止损规则</text>
        <text class="gain-desc">进场前就知道何时退出，减少情绪化操作。</text>
      </view>
    </view>
  </view>

  <!-- 三条主路径 -->
  <view class="card section-card">
    <view class="section-header">
      <text class="section-title">三条主路径</text>
      <text class="section-sub">按你的当前阶段，直接进入对应入口</text>
    </view>

    <view class="test-item" bindtap="goCalc">
      <view class="test-left">
        <view class="bullet bullet-green"></view>
        <view class="test-text">
          <text class="test-title">先做一次风控计算</text>
          <text class="test-desc">快速得到分批建仓、止损、止盈和仓位控制方案。</text>
        </view>
      </view>
      <view class="test-right">
        <text class="test-action">立即开始</text>
      </view>
    </view>

    <view class="test-item" bindtap="goCamp">
      <view class="test-left">
        <view class="bullet bullet-green"></view>
        <view class="test-text">
          <text class="test-title">进入 7 天风控训练营</text>
          <text class="test-desc">每天 1 小时，把“会亏钱”逐步改成“会控亏”。</text>
        </view>
      </view>
      <view class="test-right">
        <text class="test-action">进入训练</text>
      </view>
    </view>

    <view class="test-item" bindtap="goController">
      <view class="test-left">
        <view class="bullet bullet-green"></view>
        <view class="test-text">
          <text class="test-title">进入控局者路径</text>
          <text class="test-desc">训练营、课程日历、进阶服务统一入口。</text>
        </view>
      </view>
      <view class="test-right">
        <text class="test-action">进入</text>
      </view>
    </view>
  </view>

  <!-- 进阶承接 -->
  <view class="card section-card">
    <view class="section-header">
      <text class="section-title">进阶承接</text>
      <text class="section-sub">想系统训练、看课程、进入进阶服务，从这里继续</text>
    </view>

    <view class="test-item" bindtap="goCourseCalendar">
      <view class="test-left">
        <view class="bullet bullet-green"></view>
        <view class="test-text">
          <text class="test-title">课程日历</text>
          <text class="test-desc">查看即将开播 / 全部课程，安排你的训练节奏。</text>
        </view>
      </view>
      <view class="test-right">
        <text class="test-action">查看</text>
      </view>
    </view>

    <view class="test-item" bindtap="goMembership">
      <view class="test-left">
        <view class="bullet bullet-green"></view>
        <view class="test-text">
          <text class="test-title">进阶服务与会员</text>
          <text class="test-desc">保留付费链路入口，承接高意向用户。</text>
        </view>
      </view>
      <view class="test-right">
        <text class="test-action">进入</text>
      </view>
    </view>
  </view>

  <!-- 裂变后置 -->
  <view class="card section-card">
    <view class="section-header">
      <text class="section-title">控局者专属权益</text>
      <text class="section-sub">邀请同频朋友一起控亏，解锁更多完整风控方案次数</text>
    </view>

    <view class="benefit-list">
      <view class="benefit-item">
        <text class="benefit-tag">邀 1 人</text>
        <text class="benefit-text">解锁完整风控方案体验次数</text>
      </view>
      <view class="benefit-item">
        <text class="benefit-tag">邀 3 人</text>
        <text class="benefit-text">额外获得多次完整方案使用权</text>
      </view>
      <view class="benefit-item">
        <text class="benefit-tag">邀 10 人</text>
        <text class="benefit-text">升级为熵盾 VIP 控局者（以顾问说明为准）</text>
      </view>
    </view>

    <button class="btn-outline" bindtap="goFission">
      进入任务中心
    </button>
  </view>

  <!-- 合规提示 -->
  <view class="card notice-card">
    <view class="notice-title">重要提示</view>
    <view class="notice-text">
      <text>本小程序仅用于风险测算和学习，不构成任何投资建议。</text>
      <text>请根据自身情况审慎决策，必要时请咨询专业机构。</text>
    </view>
  </view>

</view>