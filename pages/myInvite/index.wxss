page { background: #0D0D0D; }
.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #0D0D0D;
}
.card {
  background: #111111;
  border-radius: 18rpx;
  padding: 24rpx;
  border: 1px solid rgba(42,255,42,0.18);
  box-shadow: 0 0 24rpx rgba(42,255,42,0.10);
  margin-bottom: 18rpx;
}
.title {
  color: #F2F2F2;
  font-size: 32rpx;
  font-weight: 800;
}
.sub {
  margin-top: 12rpx;
  color: rgba(255,255,255,0.65);
  font-size: 24rpx;
  word-break: break-all;
}
.btn {
  margin-top: 20rpx;
  border-radius: 14rpx;
  background: #2AFF2A;
  color: #0D0D0D;
  font-size: 26rpx;
  font-weight: 700;
}
button::after {
  border: none;
}
.sectionTitle {
  margin-bottom: 12rpx;
  color: #2AFF2A;
  font-size: 26rpx;
  font-weight: 800;
}
.item {
  background: #0B0B0B;
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 14rpx;
  padding: 18rpx;
  margin-bottom: 14rpx;
}
.line {
  display: flex;
  margin-bottom: 8rpx;
}
.k {
  width: 170rpx;
  flex: none;
  color: rgba(255,255,255,0.58);
  font-size: 24rpx;
}
.v {
  flex: 1;
  color: #EDEDED;
  font-size: 24rpx;
  word-break: break-all;
}
.empty {
  text-align: center;
  color: rgba(255,255,255,0.58);
  font-size: 24rpx;
}

.tracker-entry {
  margin-top: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.tracker-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;
  background: linear-gradient(90deg, #18b74b, #2aff2a);
  color: #020305;
  font-size: 28rpx;
  font-weight: 600;
  text-decoration: none;
  box-sizing: border-box;
}

.tracker-tip {
  display: block;
  margin-top: 10rpx;
  text-align: center;
  font-size: 22rpx;
  color: #8a8d93;
}
