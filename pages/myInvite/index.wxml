<view class="page">
  <view class="card">
    <view class="title">我的邀请</view>
    <view class="sub">自动读取当前登录用户，仅展示自己的邀请关系。</view>
    <view class="sub">当前ID：{{currentClientId}}</view>

    <button class="btn" bindtap="loadMyInvite" loading="{{loading}}">刷新</button>
    <button class="btn" bindtap="safeBack">返回个人中心</button>
    <button class="btn" bindtap="goHome">返回首页</button>
  </view>

  <view class="card" wx:if="{{shown}}">
    <view wx:if="{{found}}">
      <view class="sectionTitle">我的邀请关系</view>
      <view class="item">
        <view class="line"><text class="k">手机号：</text><text class="v">{{targetMobile}}</text></view>
        <view class="line"><text class="k">clientId：</text><text class="v">{{targetClientId}}</text></view>
        <view class="line"><text class="k">我的邀请码：</text><text class="v">{{targetCode}}</text></view>
        <view class="line"><text class="k">我的上级：</text><text class="v">{{targetParentCode}}</text></view>
        <view class="line"><text class="k">邀请人：</text><text class="v">{{targetInviterClientId}}</text></view>
        <view class="line"><text class="k">我邀请人数：</text><text class="v">{{targetInviteeCount}}</text></view>
      </view>

      <view class="sectionTitle">汇总</view>
      <view class="item">
        <view class="line"><text class="k">已关联：</text><text class="v">{{summaryLinkedCount}}</text></view>
        <view class="line"><text class="k">体验已付费：</text><text class="v">{{summaryTrialPaidCount}}</text></view>
        <view class="line"><text class="k">正式已付费：</text><text class="v">{{summaryOfficialPaidCount}}</text></view>
        <view class="line"><text class="k">已过期：</text><text class="v">{{summaryExpiredCount}}</text></view>
      </view>

      <view wx:if="{{hasInvitees}}">
        <view class="sectionTitle">我邀请的人</view>
        <block wx:for="{{invitees}}" wx:key="clientIdText">
          <view class="item">
            <view class="line"><text class="k">手机号：</text><text class="v">{{item.mobileText}}</text></view>
            <view class="line"><text class="k">clientId：</text><text class="v">{{item.clientIdText}}</text></view>
            <view class="line"><text class="k">邀请码：</text><text class="v">{{item.inviteCodeText}}</text></view>
            <view class="line"><text class="k">绑定上级：</text><text class="v">{{item.parentCodeText}}</text></view>
            <view class="line"><text class="k">关系阶段：</text><text class="v">{{item.relationStageText}}</text></view>
            <view class="line"><text class="k">最近支付分：</text><text class="v">{{item.latestPayAmountText}}</text></view>
            <view class="line"><text class="k">最近支付时间：</text><text class="v">{{item.latestPaidAtText}}</text></view>
            <view class="line"><text class="k">首单订单号：</text><text class="v">{{item.firstPaidOrderNoText}}</text></view>
          </view>
        </block>
      </view>
    </view>

    <view class="empty" wx:else>当前账号还没有邀请记录</view>
  </view>

  <view class="tracker-entry">
    <navigator
      class="tracker-btn"
      url="/pages/inviteTracker/index"
      open-type="navigate"
      hover-class="none"
    >{{trackerBtnText}}</navigator>
    <text class="tracker-tip">{{trackerTipText}}</text>
  </view>
</view>