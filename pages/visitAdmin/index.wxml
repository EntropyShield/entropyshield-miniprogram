<view class="page">

  <view class="admin-header">
    <text class="admin-title">{{texts.pageTitle}}</text>
    <text class="admin-subtitle">{{texts.pageSubtitle}}</text>
  </view>

  <view class="status-tabs">
    <block wx:for="{{statusTabs}}" wx:key="key">
      <view
        class="status-tab {{activeStatus === item.key ? 'active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onStatusTabTap"
      >
        <text class="status-tab-label">{{item.label}}</text>
        <text class="status-tab-count">{{counters[item.key] || 0}}</text>
      </view>
    </block>
  </view>

  <view wx:if="{{loading && !hasLoaded}}" class="empty">
    <text class="empty-title">{{texts.loadingTitle}}</text>
    <text class="empty-text">{{texts.loadingDesc}}</text>
  </view>

  <view wx:elif="{{filteredList.length > 0}}" class="list-wrap">
    <block wx:for="{{filteredList}}" wx:key="id">
      <view class="visit-card">
        <view class="visit-top-row">
          <view class="visit-date-time">
            <text class="visit-date">{{item.visitDateDisplay}}</text>
            <text class="visit-dot">?</text>
            <text class="visit-time">{{item.visitTimeRange || texts.timeMissing}}</text>
          </view>

          <view class="status-pill {{statusClassMap[item.status]}}">
            {{statusTextMap[item.status] || texts.unknownStatus}}
          </view>
        </view>

        <view class="visit-row">
          <text class="visit-label">{{texts.nameLabel}}</text>
          <text class="visit-value">{{item.name || texts.dash}}</text>
        </view>

        <view class="visit-row">
          <text class="visit-label">{{texts.mobileLabel}}</text>
          <text class="visit-value">{{item.mobile || texts.dash}}</text>
        </view>

        <view class="visit-row">
          <text class="visit-label">{{texts.purposeLabel}}</text>
          <text class="visit-value">{{item.purpose || texts.unfilled}}</text>
        </view>

        <view class="visit-row">
          <text class="visit-label">{{texts.remarkLabel}}</text>
          <text class="visit-value">{{item.remark || texts.dash}}</text>
        </view>

        <view class="visit-row visit-meta">
          <text class="visit-label">{{texts.createdAtLabel}}</text>
          <text class="visit-value">{{item.createdAt}}</text>
        </view>

        <view class="visit-row visit-meta">
          <text class="visit-label">{{texts.idLabel}}</text>
          <text class="visit-value">#{{item.id}} ? {{item.clientId}}</text>
        </view>

        <view class="btn-row">
          <view class="btn-group">
            <button
              class="btn-small btn-confirm {{item.id === updatingId || item.status === 2 || item.status === 3 ? 'is-disabled' : ''}}"
              size="mini"
              data-id="{{item.id}}"
              data-status="1"
              data-current-status="{{item.status}}"
              disabled="{{item.id === updatingId || item.status === 2 || item.status === 3}}"
              loading="{{item.id === updatingId && updatingToStatus === 1}}"
              bindtap="onUpdateStatusTap"
            >
              {{texts.confirmBtn}}
            </button>

            <button
              class="btn-small btn-done {{item.id === updatingId || item.status === 2 || item.status === 3 ? 'is-disabled' : ''}}"
              size="mini"
              data-id="{{item.id}}"
              data-status="2"
              data-current-status="{{item.status}}"
              disabled="{{item.id === updatingId || item.status === 2 || item.status === 3}}"
              loading="{{item.id === updatingId && updatingToStatus === 2}}"
              bindtap="onUpdateStatusTap"
            >
              {{texts.doneBtn}}
            </button>

            <button
              class="btn-small btn-cancel {{item.id === updatingId || item.status === 3 ? 'is-disabled' : ''}}"
              size="mini"
              data-id="{{item.id}}"
              data-status="3"
              data-current-status="{{item.status}}"
              disabled="{{item.id === updatingId || item.status === 3}}"
              loading="{{item.id === updatingId && updatingToStatus === 3}}"
              bindtap="onUpdateStatusTap"
            >
              {{texts.cancelBtn}}
            </button>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view wx:else class="empty">
    <text class="empty-title">{{texts.emptyTitle}}</text>
    <text class="empty-text">{{texts.emptyDesc}}</text>
  </view>

</view>
