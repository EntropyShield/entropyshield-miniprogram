/* pages/riskCalculator/index.wxss */

.page {
  background-color: #000000;
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 鏍囬鍖?*/
.title-container {
  text-align: left;
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #2aff2a;
}

.sub-title {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: #c0c0c0;
  margin-top: 10rpx;
}

/* [RC_V1_CONVERSION] 棣栧睆鎻愮ず鍗?*/
.quick-tip-card {
  margin-bottom: 24rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(42, 255, 42, 0.08);
  border: 1px solid rgba(42, 255, 42, 0.26);
}

.quick-tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #2aff2a;
  margin-bottom: 8rpx;
}

.quick-tip-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.7;
  color: #d8d8d8;
}

/* 鏉冪泭鎻愮ず鏉?*/
.rights-banner,
.rights-bar {
  margin-top: 4rpx;
  margin-bottom: 24rpx;
  padding: 14rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(42, 255, 42, 0.06);
  border: 1px solid rgba(42, 255, 42, 0.4);
  display: flex;
  align-items: flex-start;
  flex-wrap: wrap;
  row-gap: 6rpx;
}

.rights-label {
  font-size: 22rpx;
  color: #9aa0a6;
  margin-right: 8rpx;
}

.rights-text {
  flex: 1;
  font-size: 22rpx;
  line-height: 1.6;
  color: #2aff2a;
}

/* 杈撳叆鍖?*/
.input-container {
  margin-top: 10rpx;
}

.input-field {
  margin-bottom: 28rpx;
}

.label-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.input-label {
  font-size: 28rpx;
  color: #ffffff;
  display: block;
}

.label-tag {
  margin-left: 12rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.2;
}

.required-tag {
  color: #000000;
  background: #2aff2a;
}

.optional-tag {
  color: #9aa0a6;
  background: rgba(255, 255, 255, 0.08);
}

.input {
  width: 100%;
  height: 90rpx;
  box-sizing: border-box;
  padding: 0 22rpx;
  border: 2rpx solid #2aff2a;
  border-radius: 16rpx;
  background-color: #000000;
  color: #ffffff;
  font-size: 30rpx;
}

.input-error {
  border-color: #ff6b6b;
  box-shadow: 0 0 0 2rpx rgba(255, 107, 107, 0.12);
}

.field-tip {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #9aa0a6;
}

.field-error {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #ff6b6b;
}

/* 鎸夐挳鍖?*/
.button-container {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cta-tip {
  width: 85%;
  display: block;
  margin-bottom: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #d8d8d8;
  text-align: left;
}

.btn-primary,
.btn-secondary {
  width: 85%;
  padding: 22rpx 0;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
}

.btn-primary {
  background-color: #2aff2a;
}

.btn-secondary {
  background-color: transparent;
  border: 2rpx solid rgba(42, 255, 42, 0.5);
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
}

.btn-text-secondary {
  color: #2aff2a;
}

.btn-icon {
  position: absolute;
  right: 40rpx;
  font-size: 32rpx;
  color: #000000;
}

.btn-icon-secondary {
  color: #2aff2a;
}

.advanced-note {
  width: 85%;
  display: block;
  margin-top: -4rpx;
  margin-bottom: 6rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #9aa0a6;
  text-align: left;
}

/* 杩斿洖棣栭〉鎸夐挳 */
.btn-back {
  width: 90%;
  height: 88rpx;
  margin: 30rpx auto 0;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 2rpx solid #2aff2a;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  background-color: #000000;
  box-sizing: border-box;
}